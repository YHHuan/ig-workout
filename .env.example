# Copy to .env and fill in real values. .env is git-ignored.
# Worker reads these from Railway env vars; local dev reads from .env.

# --- Telegram (Phase 5) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# --- Gemini (Phase 4) ---
GEMINI_API_KEY=

# --- Cloudflare R2 (Phase 2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=workout-clips
R2_PUBLIC_BASE_URL=https://clips.example.com

# --- Supabase (Phase 2) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Cobalt (Phase 3, private Railway network) ---
COBALT_API_URL=http://cobalt.railway.internal:9000

# --- Worker behavior ---
LOG_LEVEL=INFO
ENV=dev
PUBLIC_BASE_URL=
PAGES_DEPLOY_HOOK=

# --- Site (Phase 2, used at build time by Astro) ---
PUBLIC_R2_BASE=https://clips.example.com

# --- Site edit-from-phone (Phase 3.5) ---
# Random string. Same value goes into CF Workers env vars and gets pasted
# into the phone once via `https://<site>/?auth=<EDIT_TOKEN>`. The worker
# compares it to the Bearer token on PATCH /api/clip/:id.
EDIT_TOKEN=
