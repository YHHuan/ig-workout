---
import type { Clip } from '../lib/clips';
interface Props { clip: Clip; }
const { clip } = Astro.props;
const lowConfidence = (clip.exercise_name_confidence ?? 1) < 0.7;
---
<button
  type="button"
  class:list={[
    'clip-card group relative block w-full overflow-hidden rounded-xl bg-zinc-900 text-left',
    'aspect-[3/4] focus:outline-none focus-visible:ring-2 focus-visible:ring-white',
    lowConfidence && 'border border-dashed border-amber-500/60',
  ]}
  data-id={clip.id}
  data-category={clip.category}
  data-name={clip.exercise_name}
  data-clip={clip.clip_src}
  data-thumb={clip.thumb_src}
  data-cues={JSON.stringify(clip.form_cues ?? [])}
  data-reps={clip.rep_count ?? ''}
  data-equipment={(clip.equipment ?? []).join(', ')}
>
  {clip.thumb_src ? (
    <img
      src={clip.thumb_src}
      alt=""
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover"
    />
  ) : (
    <div class="absolute inset-0 bg-gradient-to-br from-zinc-800 to-zinc-950"></div>
  )}
  <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent p-3">
    <div class="text-sm font-semibold leading-tight line-clamp-2">{clip.exercise_name}</div>
    {clip.muscle_group && (
      <div class="mt-0.5 text-[11px] uppercase tracking-wide text-zinc-400">{clip.muscle_group}</div>
    )}
  </div>
</button>
